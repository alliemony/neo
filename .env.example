# Backend
PORT=8080
DATABASE_URL=sqlite://neo.db
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
CORS_ORIGINS=http://localhost:5173
WIDGET_SERVICE_URL=http://localhost:8000

# Auth mode: "basic" (default) or "oauth"
AUTH_MODE=basic

# OAuth settings (required when AUTH_MODE=oauth)
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret
# OAUTH_ALLOWED_USERS=username1,username2
# SESSION_SECRET=change-me-to-a-random-32-byte-key
# BASE_URL=https://your-domain.com

# Frontend (Vite)
VITE_API_URL=http://localhost:8080

# Production only
# SERVE_STATIC=true
# STATIC_DIR=./static
